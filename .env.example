# Copy this file to .env before starting docker compose.
# Use strong, unique passwords in real deployments.

POSTGRES_PASSWORD=replace-this-with-a-strong-password
ADMIN_PASSWORD=replace-this-with-a-strong-password
# JWT_SECRET must be at least 32 characters. Generate with: openssl rand -base64 32
JWT_SECRET=replace-this-with-a-strong-secret

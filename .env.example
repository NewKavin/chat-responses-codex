# 复制此文件为 `.env` 后再启动 `docker compose`。
# 生产环境请使用强密码和唯一密码。

# PostgreSQL 数据库密码，网关连接数据库时使用。
POSTGRES_PASSWORD=replace-this-with-a-strong-password
# 管理员登录密码，后台控制台使用。
ADMIN_PASSWORD=replace-this-with-a-strong-password
# JWT 签名密钥，至少 32 个字符，用于签发后台登录令牌。
JWT_SECRET=replace-this-with-a-strong-secret

# 核心运行参数
# 网关监听地址，格式为 `IP:端口`。
BIND_ADDR=0.0.0.0:3001
# 文件模式下的状态文件路径，数据库模式未启用时会使用。
STATE_PATH=/data/state.json
# PostgreSQL 连接串，启用数据库模式时使用。
DATABASE_URL=postgres://chat_responses_codex@postgres/chat_responses_codex
# Redis 连接串，用于缓存和共享状态，按需启用。
REDIS_URL=redis://redis:6379/0
# 运行日志输出路径。
LOG_PATH=/logs/runtime.log
# 容器和日志使用的时区。
TZ=Asia/Shanghai
# 后台管理员用户名。
ADMIN_USERNAME=admin
# 应用名称，会显示在页面和日志中。
APP_NAME=chat-responses-codex

# 存储与缓存
# 运行日志单文件最大大小，超过后轮转。
USAGE_LOG_ROTATION_MAX_BYTES=1048576
# 运行日志归档文件最大保留数量。
USAGE_LOG_ARCHIVE_MAX_FILES=10
# 模型探测页自动刷新间隔，单位秒。
MODEL_PROBE_REFRESH_INTERVAL_SECONDS=15
# 上游模型-key 自动同步间隔，单位秒；默认关闭。
# Set to 0 to disable background model-key synchronization.
UPSTREAM_MODEL_KEY_SYNC_INTERVAL_SECONDS=0
# 自动能力探测会发送真实推理请求并消耗模型 token；默认关闭。
# 手工 capability probe 和“真实验证并应用”需管理员明确触发，触发时仍会消耗 token。
AUTOMATIC_CAPABILITY_PROBES_ENABLED=false
# 门户仪表盘缓存 TTL，单位秒。
DASHBOARD_CACHE_TTL_SECONDS=30
# PostgreSQL 连接池最大连接数。
POSTGRES_POOL_MAX_SIZE=16
# 管理端日志分页的最大页大小。
ADMIN_LOGS_PAGE_SIZE_MAX=200
# 每个上游主机保留的最大空闲 HTTP 连接数。
UPSTREAM_HTTP_POOL_MAX_IDLE_PER_HOST=32

# 重试与路由调优
# 普通 429 的默认重试等待秒数。
UPSTREAM_RATE_LIMIT_DEFAULT_RETRY_SECONDS=30
# UPSTREAM_RATE_LIMIT_RETRY_WINDOW_SECONDS is parsed for backward compatibility only.
# 精确路由冷却使用上游完整的 `Retry-After`，缺失时使用上面的默认值。
UPSTREAM_RATE_LIMIT_RETRY_WINDOW_SECONDS=300
# UPSTREAM_RATE_LIMIT_RETRY_ATTEMPTS is deprecated for real upstream 429 responses.
# 仅为旧部署兼容而解析；真实上游 429 会立即切换精确路由。
UPSTREAM_RATE_LIMIT_RETRY_ATTEMPTS=3
# UPSTREAM_RATE_LIMIT_MAX_RETRY_AFTER_SECONDS is deprecated for route-health Retry-After.
# 仅为旧部署兼容而解析；路由冷却会保留上游完整的 `Retry-After`。
UPSTREAM_RATE_LIMIT_MAX_RETRY_AFTER_SECONDS=10
# UPSTREAM_RATE_LIMIT_FORCE_RETRY_ENABLED does not force in-request waiting.
# 仅为旧部署兼容而解析；真实上游 429 会立即切换精确路由。
UPSTREAM_RATE_LIMIT_FORCE_RETRY_ENABLED=true
# Chat 请求上下文重试的最大次数。
CONTEXT_RETRY_MAX_ATTEMPTS_CHAT=2
# Chat 请求上下文重试的最小输出 token 门槛。
CONTEXT_RETRY_MIN_OUTPUT_TOKENS_CHAT=128
# Responses 请求上下文重试的最大次数。
CONTEXT_RETRY_MAX_ATTEMPTS_RESPONSES=3
# Responses 请求上下文重试的最小输出 token 门槛。
CONTEXT_RETRY_MIN_OUTPUT_TOKENS_RESPONSES=128
# 是否启用路由黏性。
ROUTING_AFFINITY_ENABLED=true
# Exact route health is process-local; run one active gateway instance per database.
# 路由黏性的存活时间，单位秒。
ROUTING_AFFINITY_TTL_SECONDS=180
# 路由黏性逃逸压力倍率，超过这个倍率时会放弃旧偏好。
ROUTING_AFFINITY_ESCAPE_PRESSURE_RATIO=1.5
# 上游连接超时时间，单位秒。
UPSTREAM_CONNECT_TIMEOUT_SECONDS=30
# 上游响应头超时时间，单位秒。
UPSTREAM_RESPONSE_HEADER_TIMEOUT_SECONDS=30
# 上游流式保活间隔，单位秒。
UPSTREAM_STREAM_KEEPALIVE_INTERVAL_SECONDS=10
# 上游流式空闲超时，单位秒。
UPSTREAM_STREAM_IDLE_TIMEOUT_SECONDS=1800
# 上游流式最长持续时间，单位秒。
UPSTREAM_STREAM_MAX_DURATION_SECONDS=86400
# Admin API 调用上游的超时时间，单位秒。
ADMIN_UPSTREAM_TIMEOUT_SECONDS=30
# 是否启用上游请求的 hedge 额外尝试。
UPSTREAM_HEDGE_ENABLED=true
# 首次 hedge 额外尝试延迟，单位毫秒。
UPSTREAM_HEDGE_DELAY_MS=12000
# 后续 hedge 尝试间隔，单位毫秒。
UPSTREAM_HEDGE_INTERVAL_MS=12000
# 每个请求允许的 hedge 额外尝试数，可设为 0。
UPSTREAM_HEDGE_MAX_EXTRA_ATTEMPTS=1

# 可选兼容回退：当未设置协议专用参数时，两个协议共用这些值。
# Chat/Responses 通用上下文重试最大次数。
# CONTEXT_RETRY_MAX_ATTEMPTS=3
# Chat/Responses 通用上下文重试最小输出 token 门槛。
# CONTEXT_RETRY_MIN_OUTPUT_TOKENS=128

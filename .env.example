# Copy this file to .env before starting docker compose.
# Use strong, unique passwords in real deployments.

POSTGRES_PASSWORD=replace-this-with-a-strong-password
ADMIN_PASSWORD=replace-this-with-a-strong-password
# JWT_SECRET must be at least 32 characters. Generate with: openssl rand -base64 32
JWT_SECRET=replace-this-with-a-strong-secret

# Context overflow self-healing (chat defaults are tuned lower than responses)
CONTEXT_RETRY_MAX_ATTEMPTS_CHAT=2
CONTEXT_RETRY_MIN_OUTPUT_TOKENS_CHAT=128
CONTEXT_RETRY_MAX_ATTEMPTS_RESPONSES=3
CONTEXT_RETRY_MIN_OUTPUT_TOKENS_RESPONSES=128

# Upstream concurrency admission retry
UPSTREAM_CONCURRENCY_RETRY_ATTEMPTS=20
UPSTREAM_CONCURRENCY_RETRY_BACKOFF_MS=50

# Upstream 429 retry controls
UPSTREAM_RATE_LIMIT_DEFAULT_RETRY_SECONDS=30
UPSTREAM_RATE_LIMIT_RETRY_WINDOW_SECONDS=300
UPSTREAM_RATE_LIMIT_RETRY_ATTEMPTS=1

# Optional compatibility fallback (applies to both protocols if protocol-specific keys are unset)
# CONTEXT_RETRY_MAX_ATTEMPTS=3
# CONTEXT_RETRY_MIN_OUTPUT_TOKENS=128

# Downstream affinity routing for better upstream cache hit rate
ROUTING_AFFINITY_ENABLED=true
ROUTING_AFFINITY_TTL_SECONDS=180
ROUTING_AFFINITY_ESCAPE_PRESSURE_RATIO=1.5

{
  "schema_version": 1,
  "revision": 2,
  "route_overrides": [],
  "bundles": [
    {
      "id": "agent_core",
      "required": [
        "text_input",
        "text_stream",
        "function_tools",
        "forced_tool_choice",
        "tool_continuation",
        "indexed_tool_argument_stream"
      ]
    },
    {
      "id": "reasoning_agent",
      "required": [
        "reasoning_output",
        "reasoning_replay",
        "reasoning_stream"
      ]
    },
    {
      "id": "image_agent",
      "required": [
        "image_https",
        "image_data_url",
        "text_stream",
        "function_tools"
      ]
    }

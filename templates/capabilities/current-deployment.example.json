  "policies": [
    {
      "id": "glm-5.2",
      "priority": 10,
      "selector": { "runtime_model": "glm-5.2" },
      "semantic": {
        "reasoning_mode": "optional",
        "reasoning_replay_required": true,
        "effort_map": { "low": "low", "medium": "medium", "high": "high" },
        "context_window": 131072,
        "max_output_tokens": 8192
      },
      "probe_candidates": {
        "token_limit_fields": ["max_tokens", "max_completion_tokens", "max_output_tokens", "omit"],
        "reasoning_controls": {
          "reasoning_effort": ["low", "medium", "high"]
        },
        "reasoning_carriers": ["reasoning_content", "responses_reasoning_item", "messages_thinking"]
      },
      "extension_probes": [
        {
          "id": "glm-5.2-service-tier",
          "protocol": "chat_completions",
          "request_patch": { "service_tier": "auto" },
          "response_predicate": { "path": "/id", "operator": "exists" }
        }
      ],
      "evidence": [
        {
          "title": "GLM 5.2",
          "url": "https://docs.bigmodel.cn/cn/guide/models/text/glm-5.2",
